# API base URL — use your PC's LAN IP when testing on a physical device.
EXPO_PUBLIC_API_URL=http://192.168.100.212:8000/api/v1

# Optional — enables Google Maps tiles on Android (recommended for production).
# Create a key at https://console.cloud.google.com/ with Maps SDK for Android enabled.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
