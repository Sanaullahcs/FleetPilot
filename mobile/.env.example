# API base URL — use your PC's LAN IP when testing on a physical device.
# Use your PC's current Wi‑Fi IP (ipconfig). Omit in Expo Go — the app auto-detects from Metro.
EXPO_PUBLIC_API_URL=http://192.168.100.5:8000/api/v1

# Required for push on the FleetPilot APK / dev build (NOT supported in Expo Go).
# 1. Run: npx eas login
# 2. Run: npx eas init   (creates/links an Expo project)
# 3. Copy the project ID from expo.dev or eas.json into this variable:
# EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Android APK push also needs Firebase Cloud Messaging:
# - Easiest: build with `npx eas build --platform android`
# - Local APK: add google-services.json and rebuild (see Expo FCM docs)

# Optional — live Google Maps tiles (parent tracking). Requires:
# 1. Billing enabled on your Google Cloud project
# 2. Maps SDK for Android + Maps SDK for iOS enabled on this key
# 3. FleetPilot APK/dev build (Expo Go uses device maps, not your key)
# Restrict the key in Google Cloud Console — do NOT commit real keys in git.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
